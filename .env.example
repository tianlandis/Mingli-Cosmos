# ============================================================
# 数字命理推演引擎 — 生产环境变量模板
# 使用：cp .env.example .env → nano .env → docker compose up -d
# ============================================================

# ═══════════════════════════════════════
# LLM Provider（选一个）
# ═══════════════════════════════════════
# 可选值: deepseek | openai | claude | local
LLM_PROVIDER=deepseek

# ═══════════════════════════════════════
# API Key（填你的 Key）
# ═══════════════════════════════════════
LLM_API_KEY=sk-your-api-key-here

# ═══════════════════════════════════════
# API Base URL（按 Provider 填写）
# ═══════════════════════════════════════
# DeepSeek:  https://api.deepseek.com/v1
# OpenAI:    https://api.openai.com/v1
# Claude:    https://api.anthropic.com/v1
# Local:     http://localhost:11434/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# ═══════════════════════════════════════
# 模型名（按 Provider 填写）
# ═══════════════════════════════════════
# DeepSeek:  deepseek-chat
# OpenAI:    gpt-4o
# Claude:    claude-sonnet-4-20250514
# Local:     qwen2.5:7b
LLM_MODEL=deepseek-chat

# ═══════════════════════════════════════
# 生成参数（可选）
# ═══════════════════════════════════════
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4096

# ═══════════════════════════════════════
# 服务器端口
# ═══════════════════════════════════════
SERVER_PORT=3001

# ═══════════════════════════════════════
# 日志（生产环境推荐开启）
# ═══════════════════════════════════════
LOG_ENABLED=true
LOG_LEVEL=info
# LOG_DIR=./logs

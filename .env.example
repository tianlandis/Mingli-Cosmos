# ============================================================
# 八字排盘 AI 服务 — 环境变量
# ============================================================
# 复制为 .env 并填入实际值
# ============================================================

# LLM Provider: deepseek | claude | openai | local
LLM_PROVIDER=local

# API Key（local/Ollama 时填任意值即可）
LLM_API_KEY=ollama

# API Base URL（不填则使用 provider 默认地址）
# deepseek:  https://api.deepseek.com/v1
# claude:    https://api.anthropic.com/v1
# openai:    https://api.openai.com/v1
# local:     http://localhost:11434/v1
# LLM_BASE_URL=

# 模型名（不填则使用 provider 默认模型）
# deepseek:  deepseek-chat
# claude:    claude-3-5-sonnet-20241022
# openai:    gpt-4o-mini
# local:     qwen2.5:7b
# LLM_MODEL=

# 生成参数（可选）
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024

# 服务器端口（默认 3001）
# SERVER_PORT=3001

# ============================================================
# Docker 构建忽略清单
# 减小构建上下文体积，加速 COPY 指令
# ============================================================

# ── 依赖 ──
node_modules

# ── Git ──
.git
.gitignore
.gitattributes

# ── CI/CD ──
.github

# ── 环境变量（由 volumes 动态注入，不打包进镜像）──
.env
.env.*
!.env.example

# ── 构建产物 ──
dist
dist-ssr

# ── 日志 ──
logs
*.log

# ── 测试相关 ──
tests
test-results
playwright-report
coverage

# ── 文档（不进入镜像）──
docs

# ── 工具脚本 ──
tools

# ── 报告 ──
reports

# ── 编辑器 & IDE ──
.vscode
.idea
*.swp
*.swo

# ── 系统文件 ──
.DS_Store
Thumbs.db

# ── 临时文件 ──
*.tmp
*.temp
.tmp

# ── 非必要文件 ──
README.md
CHANGELOG.md
CODEBUDDY.md
snap.yaml
screenshot.png
